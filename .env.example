# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-me-to-a-strong-random-value-in-production

# Server
HOST=0.0.0.0
PORT=5000

# API
API_PREFIX=/api/v1
API_RATE_LIMIT=100 per minute

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# ML Configuration
ANOMALY_CONTAMINATION=0.05
HEALTH_SCORE_WEIGHTS_UTIL=0.30
HEALTH_SCORE_WEIGHTS_ERRORS=0.30
HEALTH_SCORE_WEIGHTS_DISCARDS=0.25
HEALTH_SCORE_WEIGHTS_ANOMALY=0.15

# Thresholds
UTIL_WARNING_THRESHOLD=70.0
UTIL_CRITICAL_THRESHOLD=90.0
ERROR_WARNING_THRESHOLD=10
ERROR_CRITICAL_THRESHOLD=100
DISCARD_WARNING_THRESHOLD=50
DISCARD_CRITICAL_THRESHOLD=500

# File handling
MAX_UPLOAD_MB=50
DATA_DIR=./data

# --- Root Cause Engine v2 (RAG + LangChain LLM) ---
# Leave LLM_PROVIDER unset to use the deterministic stub LLM (dev/CI mode).
#
# Option A — OpenAI (cloud):
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
#   LLM_MODEL=gpt-4o-mini
#
# Option B — Azure OpenAI (enterprise):
#   LLM_PROVIDER=azure
#   AZURE_OPENAI_API_KEY=...
#   AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
#   AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
#
# Option C — Ollama (fully local, no cloud):
#   LLM_PROVIDER=ollama
#   OLLAMA_BASE_URL=http://localhost:11434
#   LLM_MODEL=llama3.1:8b
#
# Option D — AWS Bedrock:
#   LLM_PROVIDER=bedrock
#   AWS_REGION=us-east-1
#   LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
#
# Option E — vLLM (self-hosted OpenAI-compatible):
#   LLM_PROVIDER=vllm
#   VLLM_ENDPOINT=http://localhost:8000/v1
#   LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# RCA_V2_TOP_K=5
# RCA_V2_MIN_CONFIDENCE=0.5
# RCA_V2_MIN_SIMILARITY=0.45
# RCA_V2_STORE_PATH=./data/incidents/incident_store.json
